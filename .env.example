# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=aicoach
POSTGRES_PORT=5440

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Path to your local Google Application Default Credentials
# Windows example: c:/Users/<username>/AppData/Roaming/gcloud/application_default_credentials.json
# Mac/Linux example: ~/.config/gcloud/application_default_credentials.json
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=/path/to/your/adc.json

# Backend Settings
ALLOWED_ORIGINS=http://localhost,http://localhost:5173
